generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 用户角色表
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("merchant")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  hotels    Hotel[]

  @@map("users")
}

// 酒店基础信息表
model Hotel {
  id           Int       @id @default(autoincrement())
  merchantId   Int
  name         String
  address      String
  starRating   Int       @default(3)
  minPrice     Decimal   @default(0.00) @db.Decimal(10, 2)
  openingTime  DateTime? @db.Date
  facilities   Json?
  coverImage   String?
  gallery      Json?
  status       Int       @default(0)
  rejectReason String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  merchant     User      @relation(fields: [merchantId], references: [id])
  rooms        HotelRoom[]

  @@index([merchantId])
  @@map("hotels")
}

// 酒店房型与价格表
model HotelRoom {
  id           Int      @id @default(autoincrement())
  hotelId      Int
  roomName     String
  bedInfo      String?
  capacity     Int      @default(2)
  hasBreakfast Boolean  @default(false)
  price        Decimal  @db.Decimal(10, 2)
  stock        Int      @default(10)
  cancelPolicy String?  @default("免费取消")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  imageUrl     String?
  hotel        Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@map("hotel_rooms")
}
