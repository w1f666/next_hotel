generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 用户角色表
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("merchant")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  hotels    Hotel[]

  @@map("users")
}

// 酒店基础信息表
model Hotel {
  id           Int       @id @default(autoincrement())
  merchantId   Int
  name         String
  address      String
  starRating   Int       @default(3)
  minPrice     Decimal   @default(0.00) @db.Decimal(10, 2)
  openingTime  DateTime? @db.Date
  facilities   Json?
  coverImage   String?
  gallery      Json?
  status       Int       @default(0)
  rejectReason String?
  latitude     Float?
  longitude    Float?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  merchant     User      @relation(fields: [merchantId], references: [id])
  rooms        HotelRoom[]
  bookings     Booking[]

  @@index([merchantId])
  @@map("hotels")
}

// 酒店房型与价格表
model HotelRoom {
  id           Int       @id @default(autoincrement())
  hotelId      Int
  roomName     String
  bedInfo      String?
  capacity     Int       @default(2)
  hasBreakfast Boolean   @default(false)
  price        Decimal   @db.Decimal(10, 2)
  stock        Int       @default(10)
  cancelPolicy String?   @default("免费取消")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  imageUrl     String?
  hotel        Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  bookings     Booking[]

  @@index([hotelId])
  @@map("hotel_rooms")
}

// 订单表
model Booking {
  id          Int      @id @default(autoincrement())
  orderNo     String   @unique             // 订单号
  roomId      Int
  hotelId     Int
  guestName   String                       // 入住人姓名
  guestPhone  String                       // 入住人手机号
  checkIn     DateTime @db.Date            // 入住日期
  checkOut    DateTime @db.Date            // 离店日期
  nights      Int                          // 间夜数
  totalPrice  Decimal  @db.Decimal(10, 2)  // 总价
  status      Int      @default(0)         // 0=待确认 1=已确认 2=已取消 3=已完成
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  room        HotelRoom @relation(fields: [roomId], references: [id])
  hotel       Hotel     @relation(fields: [hotelId], references: [id])

  @@index([roomId])
  @@index([hotelId])
  @@index([orderNo])
  @@map("bookings")
}
